# Server port (default: 3001)
PORT=3001

# --- Turso migration ---
# When you're ready to switch from better-sqlite3 to Turso, uncomment these,
# run: npm uninstall better-sqlite3 && npm install @libsql/client
# then update server/db.js following the migration comment at the top of that file.
#
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
